<Window x:Class="Guitare_hero.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mini Guitar Hero" Width="800" Height="850"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

    <Window.Resources>
        <SolidColorBrush x:Key="NeonPink"   Color="#FF2D78"/>
        <SolidColorBrush x:Key="NeonBlue"   Color="#00D4FF"/>
        <SolidColorBrush x:Key="NeonYellow" Color="#FFE600"/>
        <SolidColorBrush x:Key="NeonGreen"  Color="#00FF88"/>
        <SolidColorBrush x:Key="TextMuted"  Color="#7A7A9A"/>
    </Window.Resources>

    <Border CornerRadius="16" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#080810" Offset="0"/>
                <GradientStop Color="#0D0D1E" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <!-- Barre de titre -->
                <RowDefinition Height="*"/>
                <!-- Zone de jeu -->
                <RowDefinition Height="110"/>
                <!-- Zone des touches -->
            </Grid.RowDefinitions>

            <!-- ══════ BARRE DE TITRE ══════ -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A0A2E" Offset="0"/>
                        <GradientStop Color="#0A1A2E" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🎸" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="GUITAR HERO"
                                   Foreground="{StaticResource NeonPink}"
                                   FontSize="16" FontWeight="Black"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Score centré dans la barre -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                        <TextBlock Text="SCORE  "
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="ScoreText"
                                   Text="0"
                                   Foreground="{StaticResource NeonYellow}"
                                   FontSize="22" FontWeight="Black"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Bouton fermer -->
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Width="30" Height="30"
                            Background="Transparent"
                            Foreground="{StaticResource TextMuted}"
                            BorderThickness="0"
                            FontSize="14"
                            Cursor="Hand"
                            Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- ══════ ZONE DE JEU (CANVAS) ══════ -->
            <Grid Grid.Row="1">

                <!-- Lignes de couloir verticales décoratives -->
                <Grid HorizontalAlignment="Center" Width="480">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Couloir 1 — Vert -->
                    <Border Grid.Column="0" Margin="1,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#0A1A0E" Offset="0"/>
                                <GradientStop Color="#060D08" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- Couloir 2 — Rouge -->
                    <Border Grid.Column="1" Margin="1,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#1A0A0A" Offset="0"/>
                                <GradientStop Color="#0D0606" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- Couloir 3 — Jaune -->
                    <Border Grid.Column="2" Margin="1,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#1A1A0A" Offset="0"/>
                                <GradientStop Color="#0D0D06" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- Couloir 4 — Bleu -->
                    <Border Grid.Column="3" Margin="1,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#0A0A1A" Offset="0"/>
                                <GradientStop Color="#06060D" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- Couloir 5 — Orange -->
                    <Border Grid.Column="4" Margin="1,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#1A0F0A" Offset="0"/>
                                <GradientStop Color="#0D0806" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>

                <!-- Ligne de séparation des couloirs (traits verticaux fins) -->
                <Grid HorizontalAlignment="Center" Width="480">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="1" HorizontalAlignment="Right" Background="#1A1A3A"/>
                    <Border Grid.Column="1" Width="1" HorizontalAlignment="Right" Background="#1A1A3A"/>
                    <Border Grid.Column="2" Width="1" HorizontalAlignment="Right" Background="#1A1A3A"/>
                    <Border Grid.Column="3" Width="1" HorizontalAlignment="Right" Background="#1A1A3A"/>
                </Grid>

                <!-- Canvas principal où tombent les notes -->
                <Canvas x:Name="GameCanvas"
                        HorizontalAlignment="Center"
                        Width="480"/>

                <!-- Ligne de frappe (hit line) -->
                <Border Height="3"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,110"
                        HorizontalAlignment="Center"
                        Width="480">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#FF2D78" Offset="0.2"/>
                            <GradientStop Color="#00D4FF" Offset="0.4"/>
                            <GradientStop Color="#FFE600" Offset="0.6"/>
                            <GradientStop Color="#00D4FF" Offset="0.8"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <BlurEffect Radius="4"/>
                    </Border.Effect>
                </Border>

            </Grid>

            <!-- ══════ ZONE DES TOUCHES ══════ -->
            <Border Grid.Row="2" CornerRadius="0,0,16,16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#10101E" Offset="0"/>
                        <GradientStop Color="#0A0A16" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <!-- Séparateur haut -->
                <Grid>
                    <Border Height="1" VerticalAlignment="Top">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#FF2D78" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Boutons de frappe -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="0,8,0,0">

                        <!-- Touche 1 — Vert (A) -->
                        <StackPanel Margin="6,0" HorizontalAlignment="Center">
                            <Border Width="72" Height="72" CornerRadius="36"
                                    BorderThickness="3" BorderBrush="#00FF88"
                                    Background="#0A1A0E">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00FF88" BlurRadius="14" ShadowDepth="0" Opacity="0.5"/>
                                </Border.Effect>
                                <TextBlock Text="A" Foreground="#00FF88"
                                           FontSize="24" FontWeight="Black"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="VERT" Foreground="#00FF88"
                                       FontSize="9" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Touche 2 — Rouge (Z) -->
                        <StackPanel Margin="6,0" HorizontalAlignment="Center">
                            <Border Width="72" Height="72" CornerRadius="36"
                                    BorderThickness="3" BorderBrush="#FF2D78"
                                    Background="#1A0A0E">
                                <Border.Effect>
                                    <DropShadowEffect Color="#FF2D78" BlurRadius="14" ShadowDepth="0" Opacity="0.5"/>
                                </Border.Effect>
                                <TextBlock Text="Z" Foreground="#FF2D78"
                                           FontSize="24" FontWeight="Black"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="ROUGE" Foreground="#FF2D78"
                                       FontSize="9" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Touche 3 — Jaune (E) -->
                        <StackPanel Margin="6,0" HorizontalAlignment="Center">
                            <Border Width="72" Height="72" CornerRadius="36"
                                    BorderThickness="3" BorderBrush="#FFE600"
                                    Background="#1A1A0A">
                                <Border.Effect>
                                    <DropShadowEffect Color="#FFE600" BlurRadius="14" ShadowDepth="0" Opacity="0.5"/>
                                </Border.Effect>
                                <TextBlock Text="E" Foreground="#FFE600"
                                           FontSize="24" FontWeight="Black"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="JAUNE" Foreground="#FFE600"
                                       FontSize="9" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Touche 4 — Bleu (R) -->
                        <StackPanel Margin="6,0" HorizontalAlignment="Center">
                            <Border Width="72" Height="72" CornerRadius="36"
                                    BorderThickness="3" BorderBrush="#00D4FF"
                                    Background="#0A0A1A">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00D4FF" BlurRadius="14" ShadowDepth="0" Opacity="0.5"/>
                                </Border.Effect>
                                <TextBlock Text="R" Foreground="#00D4FF"
                                           FontSize="24" FontWeight="Black"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="BLEU" Foreground="#00D4FF"
                                       FontSize="9" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Touche 5 — Orange (T) -->
                        <StackPanel Margin="6,0" HorizontalAlignment="Center">
                            <Border Width="72" Height="72" CornerRadius="36"
                                    BorderThickness="3" BorderBrush="#FF8C00"
                                    Background="#1A0F0A">
                                <Border.Effect>
                                    <DropShadowEffect Color="#FF8C00" BlurRadius="14" ShadowDepth="0" Opacity="0.5"/>
                                </Border.Effect>
                                <TextBlock Text="T" Foreground="#FF8C00"
                                           FontSize="24" FontWeight="Black"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="ORANGE" Foreground="#FF8C00"
                                       FontSize="9" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
